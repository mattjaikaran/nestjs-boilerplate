# App
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
APP_NAME=NestJS Boilerplate
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_boilerplate
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_boilerplate
DB_SSL=false
DB_LOGGING=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# WebAuthn
WEBAUTHN_RP_NAME=NestJS Boilerplate
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Redis (for rate limiting, queues, account lockout)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@yourdomain.com

# File uploads
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE_MB=10

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# OpenTelemetry (optional — set OTEL_ENABLED=false to disable)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=nestjs-boilerplate
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Admin panel — AdminJS served at /admin (omit to disable)
# Must be at least 32 characters
ADMIN_COOKIE_SECRET=change-this-to-a-random-32-char-secret!!
